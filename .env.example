# Optional — site metadata
NEXT_PUBLIC_SITE_TITLE=Sofia Dimitrova
NEXT_PUBLIC_SITE_DESCRIPTION=Contemporary artist — exhibitions and work.

# Contact page Instagram link (full URL)
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourhandle

# --- Sanity (recommended — free tier: sanity.io/pricing) ---
# Public site reads published “Project” docs. Editors use /admin (invite them in sanity.io/manage).
#
NEXT_PUBLIC_SANITY_PROJECT_ID=f8lcj2ht
NEXT_PUBLIC_SANITY_DATASET=production

# Only for CLI import script npm run import:tumblr-to-sanity — not required for the live site.
# SANITY_API_WRITE_TOKEN=

# Local Studio: npx sanity cors add http://localhost:3000 --credentials

# Clear NEXT_PUBLIC_SANITY_PROJECT_ID only if you want demo grey tiles with no CMS.

# --- Offline copy from the public site (no Tumblr API key) ---
# Re-fetch RSS + download images into the repo:
#   npm run download:site
# Optional: SITE_IMPORT_BASE=https://other-domain.art npm run download:site
# Output: src/data/site-import.json + public/site-import/** (commit both for deploy)
# Remove site-import.json to fall back to Sanity / Tumblr / demo.
#
# OCR (default on): picks a typographic slide, converts to portable text, removes that file.
#   SITE_IMPORT_OCR=0 npm run download:site
#   SITE_IMPORT_OCR_MIN_WORDS=12
#   SITE_IMPORT_OCR_MIN_CONFIDENCE=58

# --- Tumblr (optional; most people skip this) ---
# The Tumblr API needs a “consumer key” from an app registered to a Tumblr *account*.
# That only works if the blog is yours (or the artist registers the app and gives you the key).
# You cannot get a key for someone else’s blog without that. Leave unset → site uses Sanity, then demo tiles.
#
# TUMBLR_BLOG=
# TUMBLR_CONSUMER_KEY=
