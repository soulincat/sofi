# Optional — site metadata
NEXT_PUBLIC_SITE_TITLE=Sofia Dimitrova
NEXT_PUBLIC_SITE_DESCRIPTION=Contemporary artist — exhibitions and work.

# Contact page Instagram link (full URL)
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourhandle

# --- Git-backed editor mode ---
# Open /?edit=1 or /work/<slug>?edit=1 and unlock with this password.
EDIT_PASSWORD=change_me

# HMAC secret for signed edit-session cookie.
EDIT_SESSION_SECRET=replace_with_long_random_secret

# GitHub token with repo contents write access.
GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your_org_or_user
GITHUB_REPO=your_repo
GITHUB_BRANCH=main

# --- Offline copy from the public site (no Tumblr API key) ---
# Re-fetch RSS + download images into the repo:
#   npm run download:site
# Optional: SITE_IMPORT_BASE=https://other-domain.art npm run download:site
# Output: src/data/site-import.json + public/site-import/** (commit both for deploy)
# This is now optional bootstrap data.
#
# OCR (default on): picks a typographic slide, converts to portable text, removes that file.
#   SITE_IMPORT_OCR=0 npm run download:site
#   SITE_IMPORT_OCR_MIN_WORDS=12
#   SITE_IMPORT_OCR_MIN_CONFIDENCE=58
